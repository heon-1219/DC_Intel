# Copy to repo-root .env and fill in. docker-compose substitutes ${VAR} from .env;
# pytest sets its own DATABASE_URL/JWT_SECRET, so tests need none of this.
ENV=dev
DOMAIN=localhost
DATABASE_URL=sqlite+aiosqlite:////data/dcintel.db   # container path; local non-docker dev: sqlite+aiosqlite:///./data/dcintel.db
REDIS_URL=redis://redis:6379/0
JWT_SECRET=            # REQUIRED, >= 32 chars: openssl rand -hex 32
JWT_EXPIRY_MIN=1440
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=false
LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=true
MODEL_DIR=/data/models

# --- Data sources (all free tiers) — uncommented as their milestones land ---
# FRED_API_KEY=
# FINNHUB_API_KEY=
# NEWSAPI_API_KEY=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=web:dc-intel:v1.0 (by /u/your_account)
# STOCKTWITS_ACCESS_TOKEN=

# --- Twitter/X: logged-in session scraping (personal-use, free) — data-sources.md §4.1 ---
# Use a DEDICATED throwaway account; paste its cookies (NOT a password). Job self-disables if unset.
# TWITTER_ENABLED=true
# TWITTER_AUTH_TOKEN=
# TWITTER_CT0=
