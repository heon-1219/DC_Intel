# DC Intel backend config (pydantic-settings reads this file as `.env`). Copy to `.env` and edit.
# Only JWT_SECRET is REQUIRED; everything else has a safe default. External API keys are OPTIONAL —
# each source self-disables when its key is unset (the app degrades gracefully, owner standard #1).

# --- REQUIRED ---
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars-long

# --- Core (defaults shown) ---
ENV=dev
DOMAIN=localhost
# Local dev (relative path). Docker compose overrides this to sqlite+aiosqlite:////data/dcintel.db
DATABASE_URL=sqlite+aiosqlite:///./data/dcintel.db
REDIS_URL=redis://localhost:6379/0
MODEL_DIR=/data/models            # where trained model artifacts live (docker volume path)
JWT_EXPIRY_MIN=1440               # 24h access tokens
BCRYPT_ROUNDS=12
RATE_LIMIT_ENABLED=true
TRUST_PROXY=false                 # set true only behind a trusted reverse proxy (X-Forwarded-For)
LOG_LEVEL=INFO
CORS_ORIGINS=

# --- Optional external data sources (free tiers; blank = that source disables itself) ---
FINNHUB_API_KEY=                  # US fallback quotes + earnings/news
FRED_API_KEY=                     # economic-calendar release dates
NEWSAPI_API_KEY=                  # news sentiment (free tier)
REDDIT_CLIENT_ID=                 # social intel
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:dc-intel:v1.0 (by /u/dc_intel)
STOCKTWITS_ACCESS_TOKEN=
TWITTER_ENABLED=true              # X via logged-in session cookies (personal-use, free)
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
TWITTER_COOKIES_FILE=

# --- Ops / monitoring (M10; safe local-first defaults) ---
WIN_RATE_ALERT_THRESHOLD=0.50     # rolling 7d win rate below this → ERROR alert
WIN_RATE_WARN_THRESHOLD=0.52      # below the 52% ship gate → WARN
WIN_RATE_MIN_SAMPLE=30            # min graded predictions/timeframe before alerting
ALERT_WEBHOOK_URL=                # blank → alerts only to logs/alerts.log + console
ALERT_LOG_PATH=logs/alerts.log    # docker overrides to /data/logs/alerts.log
BACKUP_DIR=/data/backups          # nightly VACUUM INTO snapshots (local volume)
BACKUP_BUCKET=                    # blank → snapshots stay local (set only for a cloud deploy)
