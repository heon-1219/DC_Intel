# DC Intel backend config. Copy to `.env` and edit. pydantic-settings reads `.env`; docker compose
# also reads it for ${VAR} substitution. Only JWT_SECRET is REQUIRED; everything else has a safe
# default and external API keys are OPTIONAL — each source self-disables when blank (owner standard #1).
# IMPORTANT: keep comments on their OWN lines. An inline comment after `KEY=value` is read as part of
# the VALUE by docker-compose interpolation (e.g. an empty key would become the comment text).

# --- REQUIRED ---
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars-long

# --- Core (defaults shown) ---
ENV=dev
DOMAIN=localhost
# Local dev (relative path). Docker compose overrides this to sqlite+aiosqlite:////data/dcintel.db
DATABASE_URL=sqlite+aiosqlite:///./data/dcintel.db
REDIS_URL=redis://localhost:6379/0
# Where trained model artifacts live (docker volume path)
MODEL_DIR=/data/models
# 24h access tokens
JWT_EXPIRY_MIN=1440
BCRYPT_ROUNDS=12
RATE_LIMIT_ENABLED=true
# Set true only behind a trusted reverse proxy (X-Forwarded-For); docker compose sets it true
TRUST_PROXY=false
LOG_LEVEL=INFO
CORS_ORIGINS=

# --- Optional external data sources (free tiers; blank = that source self-disables) ---
# US fallback quotes + earnings/news
FINNHUB_API_KEY=
# economic-calendar release dates
FRED_API_KEY=
# news sentiment (free tier)
NEWSAPI_API_KEY=
# social intel
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:dc-intel:v1.0 (by /u/dc_intel)
STOCKTWITS_ACCESS_TOKEN=
# X via logged-in session cookies (personal-use, free)
TWITTER_ENABLED=true
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
TWITTER_COOKIES_FILE=

# --- Ops / monitoring (M10; safe local-first defaults) ---
# rolling 7d win rate below this -> ERROR alert
WIN_RATE_ALERT_THRESHOLD=0.50
# below the 52% ship gate -> WARN
WIN_RATE_WARN_THRESHOLD=0.52
# min graded predictions/timeframe before alerting
WIN_RATE_MIN_SAMPLE=30
# blank -> alerts only to logs/alerts.log + console
ALERT_WEBHOOK_URL=
# docker overrides to /data/logs/alerts.log
ALERT_LOG_PATH=logs/alerts.log
# nightly VACUUM INTO snapshots (local volume)
BACKUP_DIR=/data/backups
# blank -> snapshots stay local (set only for a cloud deploy)
BACKUP_BUCKET=

# --- Public ingress (optional; local-first stays the default) ---
# Cloudflare Tunnel token for serving a real domain (e.g. kctrading.xyz) with NO port-forwarding.
# Blank -> the cloudflared service stays off (it's behind the "tunnel" compose profile). To go live:
# paste the token from the Cloudflare dashboard (Zero Trust -> Networks -> Tunnels), then
#   docker compose --profile tunnel up -d
TUNNEL_TOKEN=
# Self-reported hostname (cosmetic; the app is same-origin so it isn't load-bearing).
DOMAIN=localhost
